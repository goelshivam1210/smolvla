# ============================================================================
# POST-TRAINING: Fix config + Upload to HuggingFace
# ============================================================================

# ── Cell 10: Fix n_action_steps and Upload ──────────────────────────────────
import json

# Fix n_action_steps for both checkpoints
for run_name in ["smolvla-libero-lora-r32", "smolvla-libero-lora-r8"]:
    config_path = f"./outputs/{run_name}/checkpoints/last/pretrained_model/config.json"
    try:
        with open(config_path, "r") as f:
            config = json.load(f)
        config["n_action_steps"] = 50
        with open(config_path, "w") as f:
            json.dump(config, f, indent=2)
        print(f"✅ Fixed n_action_steps for {run_name}")
    except FileNotFoundError:
        print(f"⚠️  Config not found for {run_name} — training may not have completed")

# Upload primary checkpoint
from huggingface_hub import HfApi
api = HfApi()

api.upload_folder(
    folder_path="./outputs/smolvla-libero-lora-r32/checkpoints/last/pretrained_model",
    repo_id="goelshivam1210/smolvla-libero-lora-r32",
    repo_type="model"
)
print("✅ Uploaded primary checkpoint to HuggingFace")

# Upload ablation checkpoint
api.upload_folder(
    folder_path="./outputs/smolvla-libero-lora-r8/checkpoints/last/pretrained_model",
    repo_id="goelshivam1210/smolvla-libero-lora-r8",
    repo_type="model"
)
print("✅ Uploaded ablation checkpoint to HuggingFace")

