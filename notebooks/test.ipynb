# ── Cell 4: Sanity Run (500 steps, minimal eval) ───────────────────────────
# PURPOSE: Verify everything works before committing to a long run.
# - 500 training steps (~4 min on A100)
# - Eval only at step 500, on just 2 tasks, 2 episodes each
# - Total time: ~10-15 min including eval
#
# WHAT TO CHECK:
# - Loss should decrease from ~0.3 to ~0.15
# - Grad norm should stay < 5
# - Eval should complete without errors
# - You should see success_rate metrics (even if 0%)

!rm -rf ./outputs/sanity-check

!MUJOCO_GL=egl lerobot-train \
  --policy.path=lerobot/smolvla_base \
  --policy.repo_id=goelshivam1210/smolvla-sanity-check \
  --dataset.repo_id=HuggingFaceVLA/libero \
  --env.type=libero \
  --env.task=libero_spatial \
  --env.task_ids='[0,1]' \
  --rename_map='{"observation.images.image": "observation.images.camera1", "observation.images.image2": "observation.images.camera2"}' \
  --output_dir=./outputs/sanity-check \
  --job_name=smolvla-sanity-check \
  --steps=500 \
  --batch_size=32 \
  --optimizer.lr=2e-4 \
  --eval_freq=500 \
  --save_freq=500 \
  --eval.batch_size=1 \
  --eval.n_episodes=2 \
  --policy.device=cuda \
  --policy.use_amp=true \
  --wandb.enable=true \
  --wandb.project=smolvla-libero

